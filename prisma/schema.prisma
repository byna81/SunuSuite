generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  vehicles  Vehicle[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Vehicle {
  id        String   @id @default(uuid())
  tenantId  String
  brand     String
  model     String
  year      Int
  price     Float
  usageType String   @default("sale")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

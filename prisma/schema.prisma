generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  manager
  cashier
  agent
}

enum VehicleStatus {
  disponible
  loue
  vendu
  maintenance
  indisponible
}

enum VehicleUsageType {
  sale
  rental
  mixed
}

enum VehicleContractStatus {
  brouillon
  actif
  termine
  annule
  solde
  en_retard
}

enum VehiclePaymentType {
  sale
  rental
}

enum RentStatus {
  a_payer
  partiel
  paye
  en_retard
}

enum BillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  pending
  active
  past_due
  suspended
  cancelled
  expired
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum Sector {
  immobilier
  transport
  commerce
}

enum ManualPaymentStatus {
  pending
  received
  validated
  rejected
}

enum VtcDriverStatus {
  actif
  suspendu
  sorti
}

enum VtcContractType {
  location
  pourcentage
  mixte
}

enum VtcContractStatus {
  brouillon
  actif
  suspendu
  termine
  annule
}

enum VtcPaymentStatus {
  pending
  partial
  paid
  late
}

enum VehicleMaintenanceType {
  assurance
  visite_technique
  vidange
  pneus
  reparation
  entretien
  lavage
  autre
}

enum VehicleMaintenanceStatus {
  pending
  scheduled
  done
  overdue
  cancelled
}

model Tenant {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String?                 @unique
  logoUrl                String?
  address                String?
  phone                  String?
  email                  String?
  description            String?
  currency               String                  @default("FCFA")
  createdAt              DateTime                @default(now())
  sector                 String                  @default("commerce")
  isActive               Boolean                 @default(true)

  users                  User[]
  vehicles               Vehicle[]
  vehicleCustomers       VehicleCustomer[]
  vehicleSaleContracts   VehicleSaleContract[]
  vehicleRentalContracts VehicleRentalContract[]
  vehiclePayments        VehiclePayment[]
  vehicleExpenses        VehicleExpense[]

  categories             Category[]
  products               Product[]
  sales                  Sale[]
  returns                SaleReturn[]
  stockInventories       StockInventory[]
  stockMovementsTenant   StockMovement[]

  properties             Property[]
  contracts              LeaseContract[]
  ownerPayments          OwnerPayment[]
  owners                 Owner[]
  rentPayments           RentPayment[]

  subscriptions          Subscription[]
  modules                TenantModule[]
  commerceExpenses       CommerceExpense[]
  commerceClosings       CommerceClosing[]
  realEstateExpenses     RealEstateExpense[]
  vtcDrivers           VtcDriver[]
  vehicleAssignments   VehicleAssignment[]
  vtcContracts         VtcContract[]
  vtcDriverPayments    VtcDriverPayment[]
  vtcOwnerSettlements  VtcOwnerSettlement[]
  vehicleMaintenances  VehicleMaintenance[]
}

model User {
  id                     String      @id @default(uuid())
  email                  String?     @unique
  login                  String?     @unique
  password               String
  role                   Role
  tenantId               String
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  resetCode              String?
  resetCodeExpiresAt     DateTime?
  mustChangePassword     Boolean     @default(false)

  fullName               String?
  phone                  String?
  canManageProperties    Boolean     @default(false)
  canManageTenants       Boolean     @default(false)
  canManageContracts     Boolean     @default(false)
  canManageRents         Boolean     @default(false)
  canManageOwnerPayments Boolean     @default(false)
  canViewDashboard       Boolean     @default(false)

  tenant                 Tenant      @relation(fields: [tenantId], references: [id])

  // ✅ Commerce
  sales                  Sale[]
  stockMovements         StockMovement[]
  inventories            StockInventory[] @relation("InventoryCreatedBy")
}

model Vehicle {
  id                   String             @id @default(uuid())
  tenantId             String

  brand                String
  model                String
  year                 Int

  registrationNumber   String?
  color                String?
  fuelType             String?
  transmission         String?
  mileage              Float              @default(0)

  usageType            VehicleUsageType   @default(sale)
  status               VehicleStatus      @default(disponible)

  price                Float              @default(0)
  salePrice            Float              @default(0)
  rentalPriceDay       Float              @default(0)
  rentalPriceWeek      Float              @default(0)
  rentalPriceMonth     Float              @default(0)

  insuranceExpiry      DateTime?
  technicalVisitExpiry DateTime?
  notes                String?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @default(now()) @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  saleContracts        VehicleSaleContract[]
  rentalContracts      VehicleRentalContract[]
  expenses             VehicleExpense[]
  assignments          VehicleAssignment[]
  vtcContracts         VtcContract[]
  vtcDriverPayments    VtcDriverPayment[]
  vtcOwnerSettlements  VtcOwnerSettlement[]
  maintenances         VehicleMaintenance[]

  @@unique([tenantId, registrationNumber])
}

model VehicleCustomer {
  id                  String                  @id @default(uuid())
  tenantId            String

  fullName            String
  phone               String
  email               String?
  address             String?
  idCardNumber        String?
  driverLicenseNumber String?
  notes               String?

  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @default(now()) @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  saleContracts       VehicleSaleContract[]
  rentalContracts     VehicleRentalContract[]

  @@unique([tenantId, phone])
}

model VehicleSaleContract {
  id              String                @id @default(uuid())
  tenantId        String
  vehicleId       String
  customerId      String

  saleDate        DateTime              @default(now())
  salePrice       Float
  downPayment     Float                 @default(0)
  amountPaid      Float                 @default(0)
  remainingAmount Float                 @default(0)

  status          VehicleContractStatus @default(brouillon)
  paymentMethod   String?
  reference       String?
  notes           String?

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @default(now()) @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  vehicle         Vehicle               @relation(fields: [vehicleId], references: [id])
  customer        VehicleCustomer       @relation(fields: [customerId], references: [id])
  payments        VehiclePayment[]

  @@index([tenantId, vehicleId])
  @@index([tenantId, customerId])
}

model VehicleRentalContract {
  id               String                @id @default(uuid())
  tenantId         String
  vehicleId        String
  customerId       String

  startDate        DateTime
  endDate          DateTime?

  pricingUnit      String                @default("month")
  unitPrice        Float                 @default(0)
  totalAmount      Float                 @default(0)

  depositAmount    Float                 @default(0)
  amountPaid       Float                 @default(0)
  remainingAmount  Float                 @default(0)

  status           VehicleContractStatus @default(brouillon)

  paymentFrequency String                @default("mensuel")
  dueDay           Int?
  notes            String?

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @default(now()) @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  vehicle          Vehicle               @relation(fields: [vehicleId], references: [id])
  customer         VehicleCustomer       @relation(fields: [customerId], references: [id])
  payments         VehiclePayment[]

  @@index([tenantId, vehicleId])
  @@index([tenantId, customerId])
}

model VehiclePayment {
  id               String                 @id @default(uuid())
  tenantId         String

  paymentType      VehiclePaymentType
  saleContractId   String?
  rentalContractId String?

  amount           Float
  paymentMethod    String
  reference        String?
  note             String?
  paidAt           DateTime               @default(now())

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @default(now()) @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  saleContract     VehicleSaleContract?   @relation(fields: [saleContractId], references: [id])
  rentalContract   VehicleRentalContract? @relation(fields: [rentalContractId], references: [id])

  @@index([tenantId, paymentType])
}

model VehicleExpense {
  id          String   @id @default(uuid())
  tenantId    String
  vehicleId   String

  label       String
  amount      Float
  expenseDate DateTime @default(now())
  category    String?
  supplier    String?
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([tenantId, vehicleId])
}

model Category {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[]

  @@unique([tenantId, name])
}

model Product {
  id             String               @id @default(uuid())
  tenantId       String
  categoryId     String?
  name           String
  price          Float
  stock          Int                  @default(0)
  isActive       Boolean              @default(true)
  barcode        String?
  createdAt      DateTime             @default(now())

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  category       Category?            @relation(fields: [categoryId], references: [id])
  items          SaleItem[]
  movements      StockMovement[]
  returnItems    SaleReturnItem[]
  inventoryItems StockInventoryItem[]

  @@unique([tenantId, name])
  @@unique([tenantId, barcode])
}

model StockMovement {
  id              String          @id @default(uuid())
  productId       String
  tenantId        String?
  userId          String?

  type            String
  quantity        Int
  previousStock   Int?
  newStock        Int?
  note            String?

  inventoryId     String?
  createdAt       DateTime        @default(now())

  product         Product         @relation(fields: [productId], references: [id])
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
  inventory       StockInventory? @relation(fields: [inventoryId], references: [id])

  @@index([tenantId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
}

model Sale {
  id         String      @id @default(uuid())
  tenantId   String
  cashierId  String?
  total      Float
  status     String      @default("unpaid")
  createdAt  DateTime    @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  cashier    User?       @relation(fields: [cashierId], references: [id])
  items      SaleItem[]
  payments   Payment[]
  returns    SaleReturn[]

  @@index([tenantId, createdAt])
  @@index([cashierId, createdAt])
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  productId  String
  quantity   Int
  price      Float

  sale       Sale     @relation(fields: [saleId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id           String   @id @default(uuid())
  saleId       String
  method       String
  amount       Float
  status       String   @default("paid")
  reference    String?
  phoneNumber  String?
  provider     String?
  providerRef  String?
  createdAt    DateTime @default(now())

  sale         Sale     @relation(fields: [saleId], references: [id])
}

model SaleReturn {
  id           String           @id @default(uuid())
  saleId       String
  tenantId     String
  totalRefund  Float
  reason       String?
  status       String           @default("completed")
  createdAt    DateTime         @default(now())

  sale         Sale             @relation(fields: [saleId], references: [id])
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  items        SaleReturnItem[]
  refunds      Refund[]
}

model SaleReturnItem {
  id            String      @id @default(uuid())
  saleReturnId  String
  productId     String
  quantity      Int
  unitPrice     Float
  lineTotal     Float
  restock       Boolean     @default(true)

  saleReturn    SaleReturn  @relation(fields: [saleReturnId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
}

model Refund {
  id           String      @id @default(uuid())
  saleReturnId String
  method       String
  amount       Float
  status       String      @default("paid")
  reference    String?
  createdAt    DateTime    @default(now())

  saleReturn   SaleReturn  @relation(fields: [saleReturnId], references: [id])
}

model Property {
  id            String           @id @default(uuid())
  tenantId      String
  ownerId       String?
  title         String
  type          String
  address       String
  amount        String
  status        String           @default("disponible")
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  owner         Owner?           @relation(fields: [ownerId], references: [id])
  tenants       TenantProperty[]
  contracts     LeaseContract[]
  ownerPayments OwnerPayment[]
  rentPayments  RentPayment[]
}

model TenantProperty {
  id           String           @id @default(uuid())
  propertyId   String
  name         String
  phone        String
  email        String?
  address      String?
  rent         Float            @default(0)
  startDate    DateTime
  endDate      DateTime?
  status       String           @default("actif")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  property     Property         @relation(fields: [propertyId], references: [id])
  contracts    LeaseContract[]
  rentPayments RentPayment[]
}

model LeaseContract {
  id                String         @id @default(uuid())
  tenantId          String
  propertyId        String
  tenantPropertyId  String

  startDate         DateTime
  endDate           DateTime?

  rentAmount        Float
  depositAmount     Float          @default(0)
  paymentFrequency  String         @default("mensuel")
  status            String         @default("brouillon")

  agencyPercent     Float          @default(0)
  agencyAmount      Float          @default(0)
  ownerAmount       Float          @default(0)

  notes             String?
  inventoryInNotes  String?
  inventoryOutNotes String?
  terminatedAt      DateTime?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  property          Property       @relation(fields: [propertyId], references: [id])
  tenantProperty    TenantProperty @relation(fields: [tenantPropertyId], references: [id])
}

model Owner {
  id         String         @id @default(uuid())
  tenantId   String
  name       String
  phone      String?
  email      String?
  address    String?
  createdAt  DateTime       @default(now())

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  properties Property[]
  payments   OwnerPayment[]
  vtcContracts         VtcContract[]
  vtcOwnerSettlements  VtcOwnerSettlement[]
}

model OwnerPayment {
  id            String   @id @default(uuid())
  tenantId      String
  propertyId    String
  ownerId       String

  amount        Float
  paymentMethod String
  otherMethod   String?
  reference     String?
  note          String?
  periodLabel   String?
  paidBy        String?
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  property      Property @relation(fields: [propertyId], references: [id])
  owner         Owner    @relation(fields: [ownerId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

model RentPayment {
  id               String         @id @default(uuid())
  tenantId         String
  propertyId       String
  tenantPropertyId String

  month            Int
  year             Int

  amountDue        Float
  amountPaid       Float          @default(0)
  remainingAmount  Float          @default(0)

  status           RentStatus     @default(a_payer)

  dueDate          DateTime?
  paymentDate      DateTime?
  paymentMethod    String?
  paymentReference String?

  noticeSentAt     DateTime?
  reminderSentAt   DateTime?
  receiptSentAt    DateTime?

  note             String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  property         Property       @relation(fields: [propertyId], references: [id])
  tenantProperty   TenantProperty @relation(fields: [tenantPropertyId], references: [id])

  @@unique([propertyId, tenantPropertyId, month, year])
}

model Plan {
  id               String            @id @default(uuid())
  code             String            @unique
  name             String
  sector           Sector
  billingCycle     BillingCycle
  price            Float
  currency         String            @default("XOF")
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())

  subscriptions    Subscription[]
  businessRequests BusinessRequest[]
}

model BusinessRequest {
  id                 String              @id @default(uuid())
  businessName       String
  ownerName          String
  phone              String
  email              String
  address            String?

  sector             Sector
  billingCycle       BillingCycle
  status             String              @default("pending")
  notes              String?

  planId             String?
  expectedAmount     Float?
  paymentMethod      String?
  paymentPhoneSentTo String?
  paymentReference   String?
  paymentProofUrl    String?
  paymentStatus      ManualPaymentStatus @default(pending)
  paidAmount         Float?
  paidAt             DateTime?

  createdAt          DateTime            @default(now())

  plan               Plan?               @relation(fields: [planId], references: [id])
}

model TenantModule {
  id          String   @id @default(uuid())
  tenantId    String
  sector      Sector
  isEnabled   Boolean  @default(true)
  activatedAt DateTime @default(now())
  expiresAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sector])
}

model Subscription {
  id            String              @id @default(uuid())
  tenantId      String
  planId        String
  status        SubscriptionStatus  @default(active)
  startDate     DateTime?
  endDate       DateTime?
  autoRenew     Boolean             @default(false)
  lastPaymentAt DateTime?
  suspendedAt   DateTime?
  createdAt     DateTime            @default(now())

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  plan          Plan                @relation(fields: [planId], references: [id])

  payments      SubscriptionPayment[]
}

model SubscriptionPayment {
  id              String        @id @default(uuid())
  subscriptionId  String
  amount          Float
  currency        String        @default("XOF")
  paymentMethod   String?
  status          PaymentStatus @default(pending)
  transactionRef  String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  subscription    Subscription  @relation(fields: [subscriptionId], references: [id])
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommerceExpense {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  label         String
  category      String
  amount        Float

  expenseDate   DateTime
  paymentMethod String? // cash, wave, orange_money

  note          String?

  createdAt     DateTime @default(now())
}

model CommerceClosing {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  month             Int
  year              Int

  openingBalance    Float
  totalSales        Float
  totalPayments     Float
  totalRefunds      Float
  totalExpenses     Float

  closingBalance    Float
  netResult         Float

  note              String?

  closedAt          DateTime @default(now())
  closedBy          String?
}

model RealEstateExpense {
  id            String   @id @default(uuid())
  tenantId      String

  label         String
  category      String
  amount        Float

  expenseDate   DateTime @default(now())
  paymentMethod String?
  note          String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, expenseDate])
}

enum InventoryStatus {
  draft
  validated
}

model StockInventory {
  id             String               @id @default(uuid())
  tenantId       String
  createdById    String?

  title          String
  note           String?
  status         InventoryStatus      @default(draft)

  totalTheoretical Int                @default(0)
  totalActual      Int                @default(0)
  totalGap         Int                @default(0)

  createdAt      DateTime             @default(now())
  validatedAt    DateTime?
  updatedAt      DateTime             @default(now()) @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  createdBy      User?                @relation("InventoryCreatedBy", fields: [createdById], references: [id])
  items          StockInventoryItem[]
  movements      StockMovement[]

  @@index([tenantId, createdAt])
  @@index([createdById])
}

model StockInventoryItem {
  id               String          @id @default(uuid())
  inventoryId      String
  productId        String

  theoreticalStock Int
  actualStock      Int
  gap              Int

  note             String?

  inventory        StockInventory  @relation(fields: [inventoryId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])

  @@unique([inventoryId, productId])
  @@index([productId])
}

model VtcDriver {
  id                   String            @id @default(uuid())
  tenantId             String

  fullName             String
  phone                String
  email                String?
  address              String?

  nationalIdNumber     String?
  driverLicenseNumber  String?
  licenseExpiryDate    DateTime?

  emergencyContactName  String?
  emergencyContactPhone String?

  joinDate             DateTime?
  exitDate             DateTime?

  status               VtcDriverStatus   @default(actif)
  notes                String?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @default(now()) @updatedAt

  tenant               Tenant            @relation(fields: [tenantId], references: [id])
  assignments          VehicleAssignment[]
  contracts            VtcContract[]
  payments             VtcDriverPayment[]

  @@index([tenantId, status])
  @@unique([tenantId, phone])
}

model VehicleAssignment {
  id                String      @id @default(uuid())
  tenantId          String
  vehicleId         String
  driverId          String

  assignedAt        DateTime    @default(now())
  unassignedAt      DateTime?
  isActive          Boolean     @default(true)

  note              String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @default(now()) @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  vehicle           Vehicle     @relation(fields: [vehicleId], references: [id])
  driver            VtcDriver   @relation(fields: [driverId], references: [id])

  @@index([tenantId, vehicleId])
  @@index([tenantId, driverId])
}

model VtcContract {
  id                    String             @id @default(uuid())
  tenantId              String
  vehicleId             String
  driverId              String
  ownerId               String?

  contractType          VtcContractType
  status                VtcContractStatus  @default(brouillon)

  startDate             DateTime
  endDate               DateTime?

  dailyTarget           Float              @default(0)
  weeklyTarget          Float              @default(0)
  monthlyTarget         Float              @default(0)

  fixedRentAmount       Float              @default(0)
  depositAmount         Float              @default(0)

  companyPercent        Float              @default(0)
  ownerPercent          Float              @default(0)
  driverPercent         Float              @default(0)

  notes                 String?

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @default(now()) @updatedAt

  tenant                Tenant             @relation(fields: [tenantId], references: [id])
  vehicle               Vehicle            @relation(fields: [vehicleId], references: [id])
  driver                VtcDriver          @relation(fields: [driverId], references: [id])
  owner                 Owner?             @relation(fields: [ownerId], references: [id])

  driverPayments        VtcDriverPayment[]
  ownerSettlements      VtcOwnerSettlement[]

  @@index([tenantId, vehicleId])
  @@index([tenantId, driverId])
  @@index([tenantId, status])
}

model VtcDriverPayment {
  id                String            @id @default(uuid())
  tenantId          String
  contractId        String
  vehicleId         String
  driverId          String

  periodLabel       String?
  expectedAmount    Float             @default(0)
  paidAmount        Float             @default(0)
  remainingAmount   Float             @default(0)

  paymentDate       DateTime?
  paymentMethod     String?
  reference         String?
  note              String?

  status            VtcPaymentStatus  @default(pending)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  contract          VtcContract       @relation(fields: [contractId], references: [id])
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])
  driver            VtcDriver         @relation(fields: [driverId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, driverId])
  @@index([tenantId, vehicleId])
}

model VtcOwnerSettlement {
  id                String            @id @default(uuid())
  tenantId          String
  contractId        String
  vehicleId         String
  ownerId           String

  periodLabel       String?
  grossRevenue      Float             @default(0)

  companyShare      Float             @default(0)
  ownerShare        Float             @default(0)
  driverShare       Float             @default(0)

  alreadyPaid       Float             @default(0)
  remainingToPay    Float             @default(0)

  paymentDate       DateTime?
  paymentMethod     String?
  reference         String?
  note              String?

  status            VtcPaymentStatus  @default(pending)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  contract          VtcContract       @relation(fields: [contractId], references: [id])
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])
  owner             Owner             @relation(fields: [ownerId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, vehicleId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime   @default(now())

  users      User[]
  vehicles   Vehicle[]
  categories Category[]
  products   Product[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  tenantId  String
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Vehicle {
  id        String   @id @default(uuid())
  tenantId  String
  brand     String
  model     String
  year      Int
  price     Float
  usageType String   @default("sale")
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Category {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[]

  @@unique([tenantId, name])
}

model Product {
  id         String    @id @default(uuid())
  tenantId   String
  categoryId String?
  name       String
  price      Float
  stock      Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  category   Category? @relation(fields: [categoryId], references: [id])
  items      SaleItem[]

  @@unique([tenantId, name])
}

model Sale {
  id        String   @id @default(uuid())
  tenantId  String
  total     Float
  status    String   @default("unpaid")
  createdAt DateTime @default(now())

  items     SaleItem[]
  payments  Payment[]

  // ✅ AJOUT CORRECT
  returns   SaleReturn[]
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  price     Float

  sale      Sale     @relation(fields: [saleId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id           String   @id @default(uuid())
  saleId       String
  method       String
  amount       Float
  status       String   @default("paid")
  reference    String?
  phoneNumber  String?
  provider     String?
  providerRef  String?
  createdAt    DateTime @default(now())

  sale         Sale     @relation(fields: [saleId], references: [id])
}

model SaleReturn {
  id           String   @id @default(uuid())
  saleId       String
  tenantId     String
  totalRefund  Float
  reason       String?
  status       String   @default("completed")
  createdAt    DateTime @default(now())

  // ✅ relation vers Sale
  sale         Sale     @relation(fields: [saleId], references: [id])

  items        SaleReturnItem[]
  refunds      Refund[]
}

model SaleReturnItem {
  id            String   @id @default(uuid())
  saleReturnId  String
  productId     String
  quantity      Int
  unitPrice     Float
  lineTotal     Float
  restock       Boolean  @default(true)

  saleReturn    SaleReturn @relation(fields: [saleReturnId], references: [id])
}

model Refund {
  id           String   @id @default(uuid())
  saleReturnId String
  method       String
  amount       Float
  status       String   @default("paid")
  reference    String?
  createdAt    DateTime @default(now())

  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])
}

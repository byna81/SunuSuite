generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  manager
  cashier
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String?        @unique
  logoUrl       String?
  address       String?
  phone         String?
  email         String?
  description   String?
  currency      String         @default("FCFA")
  createdAt     DateTime       @default(now())
  sector        String         @default("commerce")

  users         User[]
  vehicles      Vehicle[]
  categories    Category[]
  products      Product[]
  sales         Sale[]
  returns       SaleReturn[]
  properties    Property[]
  contracts     LeaseContract[]
  ownerPayments OwnerPayment[]
  owners        Owner[]
  rentPayments  RentPayment[]
}

model User {
  id                 String      @id @default(uuid())
  email              String?     @unique
  login              String?     @unique
  password           String
  role               Role
  tenantId           String
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  resetCode          String?
  resetCodeExpiresAt DateTime?

  tenant             Tenant      @relation(fields: [tenantId], references: [id])
}

model Vehicle {
  id        String   @id @default(uuid())
  tenantId  String
  brand     String
  model     String
  year      Int
  price     Float
  usageType String   @default("sale")
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Category {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[]

  @@unique([tenantId, name])
}

model Product {
  id          String          @id @default(uuid())
  tenantId    String
  categoryId  String?
  name        String
  price       Float
  stock       Int             @default(0)
  isActive    Boolean         @default(true)
  barcode     String?
  createdAt   DateTime        @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  category    Category?       @relation(fields: [categoryId], references: [id])
  items       SaleItem[]
  movements   StockMovement[]
  returnItems SaleReturnItem[]

  @@unique([tenantId, name])
  @@unique([tenantId, barcode])
}

model StockMovement {
  id         String   @id @default(uuid())
  productId  String
  type       String
  quantity   Int
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id])
}

model Sale {
  id         String      @id @default(uuid())
  tenantId   String
  total      Float
  status     String      @default("unpaid")
  createdAt  DateTime    @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  items      SaleItem[]
  payments   Payment[]
  returns    SaleReturn[]
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  productId  String
  quantity   Int
  price      Float

  sale       Sale     @relation(fields: [saleId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id           String   @id @default(uuid())
  saleId       String
  method       String
  amount       Float
  status       String   @default("paid")
  reference    String?
  phoneNumber  String?
  provider     String?
  providerRef  String?
  createdAt    DateTime @default(now())

  sale         Sale     @relation(fields: [saleId], references: [id])
}

model SaleReturn {
  id           String           @id @default(uuid())
  saleId       String
  tenantId     String
  totalRefund  Float
  reason       String?
  status       String           @default("completed")
  createdAt    DateTime         @default(now())

  sale         Sale             @relation(fields: [saleId], references: [id])
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  items        SaleReturnItem[]
  refunds      Refund[]
}

model SaleReturnItem {
  id            String      @id @default(uuid())
  saleReturnId  String
  productId     String
  quantity      Int
  unitPrice     Float
  lineTotal     Float
  restock       Boolean     @default(true)

  saleReturn    SaleReturn  @relation(fields: [saleReturnId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
}

model Refund {
  id           String      @id @default(uuid())
  saleReturnId String
  method       String
  amount       Float
  status       String      @default("paid")
  reference    String?
  createdAt    DateTime    @default(now())

  saleReturn   SaleReturn  @relation(fields: [saleReturnId], references: [id])
}

model Property {
  model Property {
  id            String           @id @default(uuid())
  tenantId      String
  ownerId       String?
  title         String
  type          String
  address       String
  amount        String
  status        String           @default("disponible")
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  owner         Owner?           @relation(fields: [ownerId], references: [id])
  tenants       TenantProperty[]
  contracts     LeaseContract[]
  ownerPayments OwnerPayment[]
  rentPayments  RentPayment[]
}

model TenantProperty {
  id          String           @id @default(uuid())
  propertyId  String
  name        String
  phone       String
  email       String?
  address     String?
  rent        Float            @default(0)
  startDate   DateTime
  endDate     DateTime?
  status      String           @default("actif")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  property    Property         @relation(fields: [propertyId], references: [id])
  contracts   LeaseContract[]
  rentPayments RentPayment[]
}

model LeaseContract {
  id                String         @id @default(uuid())
  tenantId          String
  propertyId        String
  tenantPropertyId  String
  startDate         DateTime
  endDate           DateTime?
  rentAmount        Float
  depositAmount     Float          @default(0)
  paymentFrequency  String         @default("mensuel")
  status            String         @default("brouillon")
  notes             String?
  inventoryInNotes  String?
  inventoryOutNotes String?
  terminatedAt      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  property          Property       @relation(fields: [propertyId], references: [id])
  tenantProperty    TenantProperty @relation(fields: [tenantPropertyId], references: [id])
}

model Owner {
  id         String         @id @default(uuid())
  tenantId   String
  name       String
  phone      String?
  email      String?
  address    String?
  createdAt  DateTime       @default(now())

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  properties Property[]
  payments   OwnerPayment[]
}

model OwnerPayment {
  id            String   @id @default(uuid())
  tenantId      String
  propertyId    String
  ownerId       String

  amount        Float
  paymentMethod String
  otherMethod   String?
  reference     String?
  note          String?
  periodLabel   String?
  paidBy        String?
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  property      Property @relation(fields: [propertyId], references: [id])
  owner         Owner    @relation(fields: [ownerId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

enum RentStatus {
  a_payer
  partiel
  paye
  en_retard
}

model RentPayment {
  id               String         @id @default(uuid())
  tenantId         String
  propertyId       String
  tenantPropertyId String

  month            Int
  year             Int

  amountDue        Float
  amountPaid       Float          @default(0)
  remainingAmount  Float          @default(0)

  status           RentStatus     @default(a_payer)

  dueDate          DateTime?
  paymentDate      DateTime?
  paymentMethod    String?
  paymentReference String?

  noticeSentAt     DateTime?
  reminderSentAt   DateTime?
  receiptSentAt    DateTime?

  note             String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  property         Property       @relation(fields: [propertyId], references: [id])
  tenantProperty   TenantProperty @relation(fields: [tenantPropertyId], references: [id])

  @@unique([propertyId, tenantPropertyId, month, year])
}

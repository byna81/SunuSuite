generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id        String   @id @default(uuid())
  tenantId  String
  brand     String
  model     String
  year      Int
  price     Float
  createdAt DateTime @default(now())
}
